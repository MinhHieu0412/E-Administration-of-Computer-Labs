@model IEnumerable<E_Administration.Models.ELearning>

@{
    ViewData["Title"] = "eLearning Index";
    Layout = "~/Areas/User/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-info text-white text-center">
            <h3>eLearning Resources Management</h3>
        </div>
        <div class="card-body">
            <div class="text-right mb-3">
                <a asp-action="Create" class="btn btn-success">Create New eLearning</a>
            </div>
            <table class="table table-striped table-hover table-responsive">
                <thead class="thead-dark">
                    <tr>
                        <th>Uploaded By</th>
                        <th>Title</th>
                        <th>Description</th>
                        <th>PDF File</th>
                        <th>Image</th>
                        <th>Created At</th>
                        <th>Updated At</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.UploadedBy</td>
                            <td>@item.Title</td>
                            <td>@item.Description</td>
                            <td>
                                <a href="@item.FilePath" target="_blank" class="text-decoration-none text-info">View PDF</a>
                            </td>
                            <td>
                                <img src="@item.Link" alt="Image" class="img-thumbnail" style="width: 100px; height: auto;" />
                            </td>
                            <td>@item.CreatedAt</td>
                            <td>@item.UpdatedAt</td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-primary btn-sm">Edit</a> | 
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
